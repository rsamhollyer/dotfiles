	"walTheme.autoUpdate": true,
	"explorer.confirmDragAndDrop": false,
	"workbench.editor.untitled.hint": "hidden",
	"workbench.sideBar.location": "right",
	"workbench.colorTheme": "Kanagawa",
	"workbench.iconTheme": "helium-icon-theme",
	"workbench.editor.tabSizing": "fit",
	"workbench.editor.scrollToSwitchTabs": true,
	"workbench.editor.enablePreview": true,
	"workbench.editor.enablePreviewFromCodeNavigation": true,
	"workbench.editorAssociations": {
		"*.ipynb": "jupyter-notebook"
	},
	"workbench.startupEditor": "newUntitledFile",
	"emmet.includeLanguages": {
		"javascript": "javascriptreact",
		"typescript": "typescriptreact"
	},
	"python.languageServer": "Pylance",
	"python.linting.enabled": true,
	"python.formatting.provider": "black",
	"python.formatting.blackPath": "/home/sam/.local/bin/black",
	"python.sortImports.path": "/home/sam/.local/bin/isort",
	"python.formatting.blackArgs": ["--line-length=90"],
	"python.sortImports.args": ["--profile=black"],
	"[python]": {
		"editor.formatOnSave": true
	},
	"python.analysis.completeFunctionParens": true,
	"python.defaultInterpreterPath": "python",
	"files.hotExit": "off",
	"github.copilot.inlineSuggest.enable": true,
	"github.copilot.advanced": {
		"debug.showScores": true,
		"inlineSuggestCount": 5,
		"listCount": 20
	},
	"github.copilot.enable": {
		"*": true,
		"yaml": false,
		"plaintext": true,
		"markdown": false
	},
	"path-autocomplete.extensionOnImport": true,
	"git.autofetch": false,
	"git.enabled": true,
	"git.confirmSync": false,
	"eslint.alwaysShowStatus": true,
	"[rust]": {
		"editor.defaultFormatter": "rust-lang.rust-analyzer",
		"editor.semanticHighlighting.enabled": true,
		"editor.formatOnSave": true
	},
	"rust-analyzer.checkOnSave.command": "clippy",
	"rust-analyzer.cargo.autoreload": true,
	"rust-analyzer.completion.autoimport.enable": true,
	"[javascript][javascriptreact][typescript][typescriptreact]": {
		"editor.formatOnSave": false,
		"editor.formatOnType": false
	},
	"typescript.suggest.paths": true,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"javascript.updateImportsOnFileMove.enabled": "always",
	"javascript.preferences.importModuleSpecifier": "relative",
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features",
		"editor.matchBrackets": "always"
	},
	"[css][scss][less]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"css.format.maxPreserveNewLines": 1,
	"css.format.enable": true,
	"css.format.newlineBetweenRules": true,
	"css.format.newlineBetweenSelectors": true,
	"css.format.spaceAroundSelectorSeparator": true,
	"css.format.braceStyle": "collapse",
	"scss.format.enable": true,
	"scss.format.newlineBetweenRules": true,
	"scss.format.newlineBetweenSelectors": true,
	"scss.format.spaceAroundSelectorSeparator": true,
	"less.format.enable": true,
	"less.format.newlineBetweenRules": true,
	"less.format.newlineBetweenSelectors": true,
	"less.format.spaceAroundSelectorSeparator": true,
	"[php]": {
		"editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
	},
	"intelephense.format.braces": "k&r",
	"intelephense.format.enable": true,
	"intelephense.diagnostics.enable": true,
	"bladeFormatter.format.enabled": true,
	"bladeFormatter.format.wrapLineLength": 135,
	"bladeFormatter.format.indentSize": 1,
	"bladeFormatter.format.wrapAttributes": "aligned-multiple",
	"bladeFormatter.format.sortTailwindcssClasses": true,
	"bladeFormatter.format.useTabs": false,
	"[blade]": {
		"editor.autoClosingBrackets": "always",
		"editor.defaultFormatter": "shufo.vscode-blade-formatter",
		"editor.formatOnSave": true
	},
	"[toml]": {
		"editor.defaultFormatter": "be5invis.toml"
	},
	"[jsonc][json][dockercompose]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[yaml][yml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"yaml.completion": true,
	"yaml.format.bracketSpacing": true,
	"yaml.format.printWidth": 100,
	"yaml.schemaStore.enable": true,
	"yaml.format.enable": true,
	"yaml.hover": true,
	"yaml.validate": true,
	"prettier.arrowParens": "avoid",
	"prettier.useTabs": true,
	"prettier.tabWidth": 2,
	"prettier.trailingComma": "all",
	"prettier.embeddedLanguageFormatting": "auto",
	"prettier.proseWrap": "always",
