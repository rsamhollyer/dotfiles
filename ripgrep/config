## Shamlessly copied from https://github.com/hantaotaohan/dotfiles/blob/master/.ripgreprc

# Exclude directories.
--glob=!{*.map,.git,node_modules,doc,vendor,pack/minpac,docs/database}

# Exclude file types.
--glob=!*.{lock}

# Exclude files.
--glob=!{package-lock.json}

# Don't let ripgrep vomit really long lines to my terminal, and show a preview.
--max-columns=150
--max-columns-preview

# Because who cares about case!?
--smart-case

# I don't like to not see hidden files.
--hidden

# Follow symbolic links.
--follow

# Don't respect ignore files (.gitignore, .ignore, etc.).
--no-ignore

# Sort by file path.
--sort=path

# Configure color settings and styles.
--colors=path:bg:0x3b,0x3b,0x3b
--colors=path:fg:magenta
--colors=line:fg:0xf2,0xc2,0x60
--colors=match:bg:0x2b,0x83,0xa6
--colors=match:fg:0xff,0xff,0xff
--colors=match:style:nobold