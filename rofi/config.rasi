/** Basic config file **/

configuration {
  show-icons: true;
  icon-theme: "Qogir-dark";
  font: "CaskaydiaCove Nerd Font 10";
  terminal: "alacritty";
  modi: "drun,run,window";
  ssh-client: "ssh";
  ssh-command: "{terminal} -e {ssh-client} {host} [-p {port}]";
  run-command: "{cmd}";
  run-shell-command: "{terminal} -e {cmd}";
  window-command: "wmctrl -i -R {window}";
  sidebar-mode: true;
}
@import "wpg.rasi"